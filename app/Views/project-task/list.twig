{% extends "base.twig" %}

{% block content %}
	<h1 class="mt-4 mb-3">Задачи</h1>

	<div class="card mb-4">
		<div class="card-header">
			<div class="d-flex justify-content-between align-items-center">
				<div>
					<i class="fas fa-file me-1"></i> Список задач
				</div>
			</div>
		</div>
		<div class="card-body">
			<div class="mb-3">
				<form method="get" class="g-3">
					<div class="row">
						<div class="col-auto">
							<label for="status" class="col-form-label">Фильтр по статусу:</label>
						</div>
						<div class="col-auto">
							<select name="status" id="status" class="form-select form-select-sm" onchange="this.form.submit()">
								<option value="">Все статусы</option>
								{% for value, label in statuses %}
									<option value="{{ value }}" {{ filter.status == value ? 'selected' : '' }}>{{ label }}</option>
								{% endfor %}
							</select>
						</div>

						{% if filter %}
							<div class="col-auto">
								<a href="{{ urlFor('tasks') }}" class="btn btn-outline-secondary btn-sm">Сбросить</a>
							</div>
						{% endif %}
					</div>
					<div class="row">
						<div class="col-auto">
							<label for="project_id" class="col-form-label">Фильтр по проекту:</label>
						</div>
						<div class="col-auto">
							<select name="project_id" id="project_id" class="form-select form-select-sm" onchange="this.form.submit()">
								<option value="">Все проекты</option>
								{% for row in projects %}
									<option value="{{ row.id }}" {{ filter.project_id == row.id ? 'selected' : '' }}>{{ row.name }}</option>
								{% endfor %}
							</select>
						</div>
					</div>
				</form>
			</div>

			{% if items is empty %}
				<p class="text-muted mb-0">Проекты не найдены</p>
			{% else %}
				<div class="table-responsive">
					<table class="table table-hover table-striped">
						<thead>
							<tr>
								<th>Название</th>
								<th>Проект</th>
								<th>Срок выполнения</th>
								<th>Статус</th>
								<th class="text-end" width="200">Действия</th>
							</tr>
						</thead>
						<tbody>
							{% for item in items %}
								<tr>
									<td>
										{% if item.isExpired() == '1' %}
											<i class="fa-solid fa-fire text-danger"></i>
										{% endif %}	

										<a href="{{ urlFor('tasks-view', {projectId: item.projectId, id: item.id}) }}" class="fw-bold">
											{{ item.name }}
										</a>
									</td>
									<td>
										<a href="{{ urlFor('projects-view', {id: item.projectId}) }}" class="text-decoration-none">
											{{ projects[item.projectId].name }}
										</a>
									</td>
									<td>{{ item.endDate|date('d.m.Y') }}</td>
									<td>
										<span class="badge {{ item.getBadgeClass() }}">
											{{ item.getStatusLabel() }}
										</span>
									</td>
									
									<td class="text-end">
										<div class="btn-group btn-group-sm" role="group">
											<a href="{{ urlFor('tasks-view', {projectId: item.projectId, id: item.id}) }}" class="btn btn-outline-primary" title="Просмотр">
												<i class="fas fa-eye"></i>
											</a>
											<a href="{{ urlFor('tasks-edit', {projectId: item.projectId, id: item.id}) }}" class="btn btn-outline-primary" title="Редактировать">
												<i class="fas fa-edit"></i>
											</a>

											{% if item.deleted != '1' %}
												<a href="{{ urlFor('tasks-archive-list', {id: item.id}) }}" class="btn btn-outline-danger" title="Архивировать" onclick="return confirm('Архивировать задачу?')">
													<i class="fas fa-archive"></i>
												</a>
											{% endif %}
										</div>
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			{% endif %}
		</div>
	</div>
{% endblock %}
