{% extends "base.twig" %}

{% block content %}
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h1 class="mb-0">{{ item.id == 'create' ? 'Редактирование задачи' : 'Новая задача' }}</h1>
		<a href="{{ item.id ? urlFor('tasks-view', {projectId: item.projectId, id: item.id}) : urlFor('projects-view', {id: project.id}) }}" class="btn btn-outline-secondary">
			<i class="fas fa-arrow-left me-1"></i> Отмена
		</a>
	</div>

	<div class="card">
		<div class="card-header">
			<i class="fas fa-box me-1"></i> {{ item.id ? 'Редактирование задачи' : 'Создание задачи' }}
		</div>
		<div class="card-body">
			<form method="post" action="">
				<div class="row">
					<div class="col-md-6 mb-3">
						<label for="status" class="form-label">Статус</label>
						<select class="form-select" id="status" name="status">
							{% for value, label in statuses %}
								<option value="{{ value }}" {{ request.status ?? item.status.value == value ? 'selected' : '' }}>
									{{ label }}
								</option>
							{% endfor %}
						</select>
					</div>
				</div>

				<div class="row">
					<div class="col-md-6 mb-3">
						<label for="name" class="form-label">Наименование <span class="text-danger">*</span></label>
						<input type="text" class="form-control" 
							   id="name" name="name" 
							   value="{{ request.name ?? item.name }}" required>
					</div>

					<div class="col-6 mb-3">
						<label for="end_date" class="form-label">Срок выполнения <span class="text-danger">*</span></label>
						<input type="date" class="form-control datepicker" 
							   id="end_date" name="end_date" 
							   value="{{ request.end_date ?? item.endDate | date('Y-m-d') }}" required>
					</div>
				</div>

				<div class="row">
					<div class="col-12 mb-3">
						<label for="description" class="form-label">Описание</label>
						<textarea class="form-control" id="description" name="description" rows="4">{{ request.description ?? item.description }}</textarea>
					</div>
				</div>

				<div class="d-flex gap-2">
					<button type="submit" class="btn btn-primary">
						<i class="fas fa-save me-1"></i> {{ item.id ? 'Сохранить' : 'Создать' }}
					</button>
					<a href="{{ item ? urlFor('tasks-view', {projectId: item.projectId, id: item.id}) : urlFor('projects-view', {id: project.id}) }}" class="btn btn-outline-secondary">
						Отмена
					</a>
				</div>
			</form>
		</div>
	</div>
{% endblock %}
