{% extends "authentication.twig" %}

{% block content %}
	<div class="card shadow-lg border-0 rounded-lg mt-5">
		<div class="card-header">
			<h3 class="text-center font-weight-light my-4">Авторизация</h3>
		</div>
		<div class="card-body">
			{% if error %}
				<div class="alert alert-danger mb-3">{{ error }}</div>
			{% endif %}

			<form action="" method="POST">
				<div class="form-floating mb-3">
					<input name="login" class="form-control" id="inputLogin" type="string" placeholder="Логин" value="{{ request.login }}" />
					<label for="inputLogin">Логин</label>
				</div>
				<div class="form-floating mb-3">
					<input name="password" class="form-control" id="inputPassword" type="password" placeholder="Пароль" />
					<label for="inputPassword">Пароль</label>
				</div>
				<div class="d-flex align-items-center justify-content-between mt-4 mb-0">
					<button type="submit" class="btn btn-primary">Войти</button>
				</div>
			</form>
		</div>
	</div>
{% endblock %}