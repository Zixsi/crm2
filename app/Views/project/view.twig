{% extends "base.twig" %}

{% block content %}
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h1 class="mb-0">Карточка проекта</h1>
		<div>
			<a href="{{ urlFor('projects-edit', {id: project.id}) }}" class="btn btn-primary">
				<i class="fas fa-edit me-1"></i> Редактировать
			</a>
			<a href="{{ urlFor('projects') }}" class="btn btn-outline-secondary">
				<i class="fas fa-arrow-left me-1"></i> Назад к списку
			</a>
		</div>
	</div>

	<div class="row">
		<div class="col-lg-8">
			<div class="card mb-4">
				<div class="card-header">
					<i class="fas fa-box me-1"></i> Основная информация
				</div>
				<div class="card-body">
					<div class="row mb-3">
						<div class="col-md-6">
							<label class="text-muted small">Наименование</label>
							<p class="mb-0 fw-bold">{{ project.name }}</p>
						</div>
						<div class="col-md-6">
							<label class="text-muted small">Статус</label>
							<p class="mb-0">
								<span class="badge {{ project.getBadgeClass() }}">
									{{ project.getStatusLabel() }}
								</span>
							</p>
						</div>
					</div>
					<div class="row mb-3">
						<div class="col-md-6">
							<label class="text-muted small">Клиент</label>
							<p class="mb-0">
								<a href="{{ urlFor('clients-view', {id: project.clientId}) }}" class="text-decoration-none">
									{{ clients[project.clientId].name }}
								</a>
							</p>
						</div>
					</div>
					<div class="row">
						<div class="col-md-6">
							<label class="text-muted small">Описание</label>
							<p class="mb-0">
								{% if project.description %}
									{{ project.description }}
								{% else %}
									<span class="text-muted">—</span>
								{% endif %}
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="col-lg-4">
			<div class="card mb-4">
				<div class="card-header">
					<i class="fas fa-clock me-1"></i> Даты
				</div>
				<div class="card-body">
					<div class="mb-3">
						<label class="text-muted small">Дата начала</label>
						<p class="mb-0">{{ project.startDate|date('d.m.Y')}}</p>
					</div>
					<div>
						<label class="text-muted small">Планируемая дата завершения</label>
						<p class="mb-0">{{ project.endDate|date('d.m.Y') }}</p>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="row">
		<div class="col-12">
			<div class="card mb-4">
				<div class="card-header">
					<div class="d-flex justify-content-between align-items-center">
						<div>
							<i class="fas fa-list me-1"></i> Задачи
						</div>
						<a href="{{ urlFor('tasks-add', {projectId: project.id}) }}" class="btn btn-primary btn-sm">
							<i class="fas fa-plus me-1"></i> Добавить
						</a>
					</div>
				</div>
				<div class="card-body">
					{% if tasks is empty %}
						<p class="text-muted mb-0">Список задач пуст</p>
					{% else %}
						<div class="table-responsive">
							<table class="table table-hover table-striped">
								<thead>
									<tr>
										<th>Название</th>
										<th  width="200" class="text-end">Срок выполнения</th>
										<th  width="200" class="text-end">Статус</th>
										<th class="text-end" width="200">Действия</th>
									</tr>
								</thead>
								<tbody>
									{% for row in tasks %}
										<tr>
											<td>
												{% if row.isExpired() == '1' %}
													<i class="fa-solid fa-fire text-danger"></i>
												{% endif %}	
												<a href="{{ urlFor('tasks-view', {projectId: project.id, id: row.id}) }}" class="text-decoration-none">
													{{ row.name }}
												</a>
											</td>
											<td class="text-end">{{ row.endDate|date('d.m.Y H:i:s') }}</td>
											<td class="text-end">
												<span class="badge {{ row.getBadgeClass() }}">
													{{ row.getStatusLabel() }}
												</span>
											</td>
											<td class="text-end">
												<div class="btn-group btn-group-sm" role="group">
													<a href="{{ urlFor('tasks-view', {projectId: project.id, id: row.id}) }}" class="btn btn-outline-primary" title="Просмотр">
														<i class="fas fa-eye"></i>
													</a>
													<a href="{{ urlFor('tasks-edit', {projectId: project.id, id: row.id}) }}" class="btn btn-outline-primary" title="Редактировать">
														<i class="fas fa-edit"></i>
													</a>

													{% if row.deleted != '1' %}
														<a href="{{ urlFor('tasks-archive', {projectId: project.id, id: row.id}) }}" class="btn btn-outline-danger" title="Архивировать" onclick="return confirm('Архивировать задачу?')">
															<i class="fas fa-archive"></i>
														</a>
													{% endif %}
												</div>
											</td>
										</tr>
									{% endfor %}
								</tbody>
							</table>
						</div>
					{% endif %}
				</div>
			</div>
		</div>
	</div>
{% endblock %}
