{% extends "base.twig" %}

{% block content %}
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h1 class="mb-0">{{ project.id == 'create' ? 'Редактирование проектв' : 'Новый проект' }}</h1>
		<a href="{{ project.id ? urlFor('projects-view', {id: project.id}) : urlFor('projects') }}" class="btn btn-outline-secondary">
			<i class="fas fa-arrow-left me-1"></i> Отмена
		</a>
	</div>

	<div class="card">
		<div class="card-header">
			<i class="fas fa-box me-1"></i> {{ project.id ? 'Редактирование проекта' : 'Создание проекта' }}
		</div>
		<div class="card-body">
			<form method="post" action="">
				<div class="row">
					<div class="col-md-6 mb-3">
						<label for="name" class="form-label">Наименование <span class="text-danger">*</span></label>
						<input type="text" class="form-control" 
							   id="name" name="name" 
							   value="{{ request.name ?? project.name }}" required>
					</div>

					<div class="col-md-6 mb-3">
						<label for="client_id" class="form-label">Клиент</label>
						{% if project.id %}
						<input type="text" class="form-control" value="{{ clients[project.clientId].name }}" disabled>
						{% else %}
						<select class="form-select" id="client_id" name="client_id">
							{% for row in clients %}
								<option value="{{ row.id }}" {{ request.client_id ?? project.clientId == row.id ? 'selected' : '' }}>
									{{ row.name }}
								</option>
							{% endfor %}
						</select>
						{% endif %}
					</div>
				</div>

				<div class="row">
					<div class="col-6 mb-3">
						<label for="start_date" class="form-label">Дата начала <span class="text-danger">*</span></label>
						<input type="date" class="form-control datepicker" 
							   id="start_date" name="start_date" 
							   value="{{ (request.start_date ?? project.startDate) | date('Y-m-d') }}" required>
					</div>

					<div class="col-6 mb-3">
						<label for="end_date" class="form-label">Планируемая дата завершения <span class="text-danger">*</span></label>
						<input type="date" class="form-control datepicker" 
							   id="end_date" name="end_date" 
							   value="{{ request.end_date ?? project.endDate | date('Y-m-d') }}" required>
					</div>

				</div>

				<div class="row">
					<div class="col-12 mb-3">
						<label for="description" class="form-label">Описание</label>
						<textarea class="form-control" id="description" name="description" rows="4">{{ request.description ?? project.description }}</textarea>
					</div>
				</div>

				<div class="d-flex gap-2">
					<button type="submit" class="btn btn-primary">
						<i class="fas fa-save me-1"></i> {{ project.id ? 'Сохранить' : 'Создать' }}
					</button>
					<a href="{{ project ? urlFor('projects-view', {id: project.id}) : urlFor('projects') }}" class="btn btn-outline-secondary">
						Отмена
					</a>
				</div>
			</form>
		</div>
	</div>
{% endblock %}
