{% extends "base.twig" %}

{% block content %}
	<h1 class="mt-4 mb-3">Проекты</h1>

	<div class="card mb-4">
		<div class="card-header">
			<div class="d-flex justify-content-between align-items-center">
				<div>
					<i class="fas fa-boxes me-1"></i> Список проектов
				</div>
				<a href="{{ urlFor('projects-add') }}" class="btn btn-primary btn-sm">
					<i class="fas fa-plus me-1"></i> Добавить проект
				</a>
			</div>
		</div>
		<div class="card-body">
			<div class="mb-3">
				<form method="get" class="g-3">
					<div class="row">
						<div class="col-auto">
							<label for="status" class="col-form-label">Фильтр по статусу:</label>
						</div>
						<div class="col-auto">
							<select name="status" id="status" class="form-select form-select-sm" onchange="this.form.submit()">
								<option value="">Все статусы</option>
								{% for value, label in statuses %}
									<option value="{{ value }}" {{ filter.status == value ? 'selected' : '' }}>{{ label }}</option>
								{% endfor %}
							</select>
						</div>

						{% if filter %}
							<div class="col-auto">
								<a href="{{ urlFor('projects') }}" class="btn btn-outline-secondary btn-sm">Сбросить</a>
							</div>
						{% endif %}
					</div>
					<div class="row">
						<div class="col-auto">
							<label for="client_id" class="col-form-label">Фильтр по клиенту:</label>
						</div>
						<div class="col-auto">
							<select name="client_id" id="client_id" class="form-select form-select-sm" onchange="this.form.submit()">
								<option value="">Все клиенты</option>
								{% for row in clients %}
									<option value="{{ row.id }}" {{ filter.client_id == row.id ? 'selected' : '' }}>{{ row.name }}</option>
								{% endfor %}
							</select>
						</div>
					</div>
				</form>
			</div>

			{% if projects is empty %}
				<p class="text-muted mb-0">Проекты не найдены</p>
			{% else %}
				<div class="table-responsive">
					<table class="table table-hover table-striped">
						<thead>
							<tr>
								<th>Наименование</th>
								<th>Клиент</th>
								<th>Статус</th>
								<th class="text-end" width="200">Плановая дата завершения</th>
								<th class="text-end" width="200">Действия</th>
							</tr>
						</thead>
						<tbody>
							{% for project in projects %}
								<tr>
									<td>
										<a href="{{ urlFor('projects-view', {id: project.id}) }}" class="fw-bold">
											{{ project.name }}
										</a>
									</td>
									<td>
										<a href="{{ urlFor('clients-view', {id: project.clientId}) }}" class="text-decoration-none">
											{{ clients[project.clientId].name }}
										</a>
									</td>
									<td>
										<span class="badge {{ project.getBadgeClass() }}">
											{{ project.getStatusLabel() }}
										</span>
									</td>
									<td class="text-end">{{ project.endDate|date('d.m.Y') }}</td>
									<td class="text-end">
										<div class="btn-group btn-group-sm" role="group">
											<a href="{{ urlFor('projects-view', {id: project.id}) }}" class="btn btn-outline-primary" title="Просмотр">
												<i class="fas fa-eye"></i>
											</a>
											<a href="{{ urlFor('projects-edit', {id: project.id}) }}" class="btn btn-outline-primary" title="Редактировать">
												<i class="fas fa-edit"></i>
											</a>

											{% if project.deleted != '1' %}
												<a href="{{ urlFor('projects-archive', {id: project.id}) }}" class="btn btn-outline-danger" title="Архивировать" onclick="return confirm('Архивировать проект?')">
													<i class="fas fa-archive"></i>
												</a>
											{% endif %}
										</div>
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			{% endif %}
		</div>
	</div>
{% endblock %}
