{% extends "base.twig" %}

{% block content %}
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h1 class="mb-0">Карточка клиента</h1>
		<div>
			<a href="{{ urlFor('clients-edit', {id: client.id}) }}" class="btn btn-primary">
				<i class="fas fa-edit me-1"></i> Редактировать
			</a>
			<a href="{{ urlFor('clients') }}" class="btn btn-outline-secondary">
				<i class="fas fa-arrow-left me-1"></i> Назад к списку
			</a>
		</div>
	</div>

	<div class="row">
		<div class="col-lg-8">
			<div class="card mb-4">
				<div class="card-header">
					<i class="fas fa-user-tie me-1"></i> Основная информация
				</div>
				<div class="card-body">
					<div class="row mb-3">
						<div class="col-md-6">
							<label class="text-muted small">Наименование</label>
							<p class="mb-0 fw-bold">{{ client.name }}</p>
						</div>
						<div class="col-md-6">
							<label class="text-muted small">Статус</label>
							<p class="mb-0">
								<span class="badge {{ client.getBadgeClass() }}">
									{{ client.getStatusLabel() }}
								</span>
							</p>
						</div>
					</div>
					<div class="row mb-3">
						<div class="col-md-6">
							<label class="text-muted small">Контактное лицо</label>
							<p class="mb-0">{{ client.contactPerson }}</p>
						</div>
						<div class="col-md-6">
							<label class="text-muted small">Телефон</label>
							<p class="mb-0">
								<a href="tel:{{ client.phone }}">{{ client.phone }}</a>
							</p>
						</div>
					</div>
					<div class="row">
						<div class="col-md-6">
							<label class="text-muted small">Email</label>
							<p class="mb-0">
								{% if client.email %}
									<a href="mailto:{{ client.email }}">{{ client.email }}</a>
								{% else %}
									<span class="text-muted">—</span>
								{% endif %}
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="col-lg-4">
			<div class="card mb-4">
				<div class="card-header">
					<i class="fas fa-clock me-1"></i> Даты
				</div>
				<div class="card-body">
					<div class="mb-3">
						<label class="text-muted small">Создан</label>
						<p class="mb-0">{{ client.createdAt ? client.createdAt|date('d.m.Y H:i:s') : '—' }}</p>
					</div>
					<div>
						<label class="text-muted small">Обновлён</label>
						<p class="mb-0">{{ client.updatedAt ? client.updatedAt|date('d.m.Y H:i:s') : '—' }}</p>
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="row">
		<div class="col-12">
			<div class="card mb-4">
				<div class="card-header">
					<div class="d-flex justify-content-between align-items-center">
						<div>
							<i class="fas fa-list me-1"></i> Коммуникации
						</div>
						<a href="{{ urlFor('client-notes-add', {clientId: client.id}) }}" class="btn btn-primary btn-sm">
							<i class="fas fa-plus me-1"></i> Добавить
						</a>
					</div>
				</div>
				<div class="card-body">
					{% if notes is empty %}
						<p class="text-muted mb-0">Список коммуникаций пуст</p>
					{% else %}
						<div class="table-responsive">
							<table class="table table-hover table-striped">
								<thead>
									<tr>
										<th width="200">Дата</th>
										<th>Сообщение</th>
										<th class="text-end" width="200">Действия</th>
									</tr>
								</thead>
								<tbody>
									{% for note in notes %}
										<tr>
											<td>{{ note.createdAt|date('d.m.Y H:i:s') }}</td>
											<td>{{ note.message }}</td>
											<td class="text-end">
												<div class="btn-group btn-group-sm" role="group">
													<a href="{{ urlFor('client-notes-edit', {clientId: client.id, id: note.id}) }}" class="btn btn-outline-primary" title="Редактировать">
														<i class="fas fa-edit"></i>
													</a>
												</div>
											</td>
										</tr>
									{% endfor %}
								</tbody>
							</table>
						</div>
					{% endif %}
				</div>
			</div>
		</div>
	</div>
{% endblock %}
