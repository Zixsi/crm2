{% extends "base.twig" %}

{% block content %}
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h1 class="mb-0">{{ client.id == 'create' ? 'Редактирование клиента' : 'Новый клиент' }}</h1>
		<a href="{{ client.id ? urlFor('clients-view', {id: client.id}) : urlFor('clients') }}" class="btn btn-outline-secondary">
			<i class="fas fa-arrow-left me-1"></i> Отмена
		</a>
	</div>

	<div class="card">
		<div class="card-header">
			<i class="fas fa-user-tie me-1"></i> {{ client.id ? 'Редактирование клиента' : 'Создание клиента' }}
		</div>
		<div class="card-body">
			<form method="post" action="">
				<div class="row">
					<div class="col-md-6 mb-3">
						<label for="status" class="form-label">Статус сделки</label>
						<select class="form-select" id="status" name="status">
							{% for value, label in statuses %}
								<option value="{{ value }}" {{ request.status ?? client.status.value == value ? 'selected' : '' }}>
									{{ label }}
								</option>
							{% endfor %}
						</select>
					</div>
				</div>
				
				<div class="row">
					<div class="col-md-6 mb-3">
						<label for="name" class="form-label">Наименование <span class="text-danger">*</span></label>
						<input type="text" class="form-control" 
							   id="name" name="name" 
							   value="{{ request.name ?? client.name }}" required>
					</div>

					<div class="col-md-6 mb-3">
						<label for="contact_person" class="form-label">Контактное лицо <span class="text-danger">*</span></label>
						<input type="text" class="form-control" 
							   id="contact_person" name="contact_person" 
							   value="{{ request.contact_person ?? client.contactPerson }}" required>
					</div>
				</div>

				<div class="row">
					<div class="col-md-6 mb-3">
						<label for="phone" class="form-label">Телефон <span class="text-danger">*</span></label>
						<input type="text" class="form-control" 
							   id="phone" name="phone" 
							   value="{{ request.phone ?? client.phone }}" required>
					</div>

					<div class="col-md-6 mb-3">
						<label for="email" class="form-label">Email <span class="text-danger">*</span></label>
						<input type="email" class="form-control" 
							   id="email" name="email" 
							   value="{{ request.email ?? client.email }}" required>
					</div>
				</div>

				<div class="d-flex gap-2">
					<button type="submit" class="btn btn-primary">
						<i class="fas fa-save me-1"></i> {{ client.id ? 'Сохранить' : 'Создать' }}
					</button>
					<a href="{{ client ? urlFor('clients-view', {id: client.id}) : urlFor('clients') }}" class="btn btn-outline-secondary">
						Отмена
					</a>
				</div>
			</form>
		</div>
	</div>
{% endblock %}
