{% extends "base.twig" %}

{% block content %}
	<h1 class="mt-4 mb-3">Клиенты</h1>

	<div class="card mb-4">
		<div class="card-header">
			<div class="d-flex justify-content-between align-items-center">
				<div>
					<i class="fas fa-users me-1"></i> Список клиентов
				</div>
				<a href="{{ urlFor('clients-add') }}" class="btn btn-primary btn-sm">
					<i class="fas fa-plus me-1"></i> Добавить клиента
				</a>
			</div>
		</div>
		<div class="card-body">
			<div class="mb-3">
				<form method="get" class="row g-3">
					<div class="col-auto">
						<label for="status" class="col-form-label">Фильтр по статусу:</label>
					</div>
					<div class="col-auto">
						<select name="status" id="status" class="form-select form-select-sm" onchange="this.form.submit()">
							<option value="">Все статусы</option>
							{% for value, label in statuses %}
								<option value="{{ value }}" {{ filter.status == value ? 'selected' : '' }}>{{ label }}</option>
							{% endfor %}
						</select>
					</div>
					{% if filter %}
						<div class="col-auto">
							<a href="{{ urlFor('clients') }}" class="btn btn-outline-secondary btn-sm">Сбросить</a>
						</div>
					{% endif %}
				</form>
			</div>

			{% if clients is empty %}
				<p class="text-muted mb-0">Клиенты не найдены</p>
			{% else %}
				<div class="table-responsive">
					<table class="table table-hover table-striped">
						<thead>
							<tr>
								<th width="150">Статус</th>
								<th>Наименование</th>
								<th class="text-end" width="200">Дата</th>
								<th class="text-end" width="200">Действия</th>
							</tr>
						</thead>
						<tbody>
							{% for client in clients %}
								<tr>
									<td>
										<span class="badge {{ client.getBadgeClass() }}">
											{{ client.getStatusLabel() }}
										</span>
									</td>
									<td>
										<a href="{{ urlFor('clients-view', {id: client.id}) }}" class="fw-bold">
											{{ client.name }}
										</a>
									</td>
									<td class="text-end">{{ client.createdAt|date('d.m.Y H:i:s') }}</td>
									<td class="text-end">
										<div class="btn-group btn-group-sm" role="group">
											<a href="{{ urlFor('clients-view', {id: client.id}) }}" class="btn btn-outline-primary" title="Просмотр">
												<i class="fas fa-eye"></i>
											</a>
											<a href="{{ urlFor('clients-edit', {id: client.id}) }}" class="btn btn-outline-primary" title="Редактировать">
												<i class="fas fa-edit"></i>
											</a>
											{% if client.status.value != 'archive' %}
												<a href="{{ urlFor('clients-archive', {id: client.id}) }}" class="btn btn-outline-danger" title="Архивировать" onclick="return confirm('Архивировать клиента?')">
													<i class="fas fa-archive"></i>
												</a>
											{% endif %}
										</div>
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			{% endif %}
		</div>
	</div>
{% endblock %}
